# Secrets for the NovaMind AI edge functions.
# Local dev:  supabase functions serve --env-file supabase/functions/.env
# Production:  supabase secrets set --env-file supabase/functions/.env
#
# Never commit the filled-in .env. SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY
# are injected automatically by the Supabase runtime — do not set them here.

FEATHERLESS_API_KEY=
# Optional overrides (sensible defaults are built in):
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# FEATHERLESS_TEXT_MODEL=google/gemma-3-27b-it
# FEATHERLESS_VISION_MODEL=google/gemma-3-27b-it

ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_turbo_v2_5
# ELEVENLABS_STT_MODEL=scribe_v1   # speech-to-text (voice input) model
# ELEVENLABS_AGENT_ID=             # Conversational AI agent id (live voice tutor)
