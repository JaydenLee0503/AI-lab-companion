# Copy to .env.local and fill in. Vite only exposes vars prefixed with VITE_.
# Never commit a filled-in env file. These are PUBLIC, browser-safe values:
# the anon key is meant for the client and is gated by row-level security.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
