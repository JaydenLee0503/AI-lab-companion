{
  "manifest_version": 3,
  "name": "Focus Guard — NovaMind AI",
  "version": "1.0.0",
  "description": "Local alerts when you open distracting sites during a lab. Optional AI-written nudges are OFF by default; only when you turn them on does your active tab's hostname go to NovaMind's server.",
  "permissions": ["tabs", "storage", "notifications", "tts"],
  "host_permissions": ["https://*.supabase.co/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Guard",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
